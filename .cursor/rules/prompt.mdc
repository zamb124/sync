### Frontend (JavaScript)
```javascript
// Все компоненты наследуются от BaseComponent
import { BaseComponent } from '../core/BaseComponent.js';

export class MyComponent extends BaseComponent {
    async init() {
        const html = await this.render('template.html', { data });
        this.api.get('/path');  // API через this.api
        this.success('OK');     // Уведомления
    }
}

// Модалки наследуются от BaseModal/FormModal
// API через this.api (автоматический refresh token)
